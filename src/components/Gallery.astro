---
import type { GalleryItem } from '../data/projects';
interface Props { items: GalleryItem[] }
const { items } = Astro.props;
const multi = items.length > 1;
---

<section class="gallery-section">
  <p class="label" style="margin-bottom:1.25rem;">Gallery</p>

  <div class="carousel">
    <div class="carousel-viewport">
      <div class="carousel-track" id="cTrack">
        {items.map((item, i) => (
          <div class="carousel-slide">
            {item.type === 'image' ? (
              <img
                src={item.src}
                alt={item.caption ?? ''}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            ) : (
              <video src={item.src} muted loop playsinline preload="metadata" />
            )}
          </div>
        ))}
      </div>
    </div>

    <p class="carousel-caption" id="cCaption">{items[0]?.caption ?? ' '}</p>

    <div class="carousel-bar">
      <div class="c-dots" id="cDots">
        {items.map((_, i) => (
          <button class="c-dot" data-i={i} aria-label={`Slide ${i + 1}`} />
        ))}
      </div>
      <div class="c-actions">
        {multi && (
          <>
            <button class="c-btn" id="cPrev" aria-label="Previous slide" title="Previous">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 8H3M7 4l-4 4 4 4"/></svg>
            </button>
            <button class="c-btn" id="cPause" aria-label="Pause" title="Pause">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" id="cPauseIcon">
                <rect x="4" y="3" width="3" height="10" rx="1"/>
                <rect x="9" y="3" width="3" height="10" rx="1"/>
              </svg>
            </button>
            <button class="c-btn" id="cNext" aria-label="Next slide" title="Next">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </button>
          </>
        )}
        <button class="c-btn" id="cEnlarge" aria-label="Enlarge" title="Enlarge">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2h4v4M6 14H2v-4M2 2l5 5M14 14l-5-5"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<div class="lightbox" id="cLightbox" role="dialog" aria-modal="true" aria-label="Media viewer" hidden>
  <button class="lb-close" id="lbClose" aria-label="Close">
    <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M2 2l12 12M14 2L2 14"/></svg>
  </button>
  {multi && (
    <button class="lb-nav lb-prev" id="lbPrev" aria-label="Previous">
      <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 8H3M7 4l-4 4 4 4"/></svg>
    </button>
  )}
  <div class="lb-media" id="lbMedia"></div>
  {multi && (
    <button class="lb-nav lb-next" id="lbNext" aria-label="Next">
      <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </button>
  )}
  <p class="lb-caption" id="lbCaption"></p>
</div>

<style>
.gallery-section {
  padding-block: 3rem;
  border-bottom: 1px solid var(--line);
}

/* ── Carousel ── */
.carousel {
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  background: var(--surface);
}

.carousel-viewport {
  overflow: hidden;
  cursor: zoom-in;
  height: 480px;
}

.carousel-track {
  display: flex;
  height: 100%;
  transition: transform 0.42s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  will-change: transform;
}

.carousel-slide {
  flex: 0 0 100%;
  min-width: 0;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface);
}

/* Let content define its own size — no forced width */
.carousel-slide img,
.carousel-slide video {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  display: block;
}

.carousel-caption {
  font-size: 0.75rem;
  color: var(--text-3);
  padding: 0.5rem 1rem;
  min-height: 1.875rem;
  border-top: 1px solid var(--border);
  line-height: 1.4;
}

.carousel-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.5rem 0.625rem;
  border-top: 1px solid var(--border);
  gap: 0.5rem;
}

.c-dots {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  flex: 1;
}

.c-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--border);
  border: none;
  padding: 0;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
  flex-shrink: 0;
}

.c-dot.active {
  background: var(--text);
  transform: scale(1.3);
}

.c-actions {
  display: flex;
  align-items: center;
  gap: 0.125rem;
}

.c-btn {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  color: var(--text-3);
  cursor: pointer;
  border-radius: 4px;
  transition: color 0.15s, background 0.15s;
  padding: 0;
}

.c-btn:hover {
  color: var(--text);
  background: color-mix(in srgb, var(--border) 60%, transparent);
}

/* ── Lightbox ── */
.lightbox {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: rgba(0, 0, 0, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.lightbox[hidden] { display: none; }

.lb-close {
  position: absolute;
  top: 1rem;
  right: 1rem;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.8);
  cursor: pointer;
  border-radius: 50%;
  transition: background 0.15s;
  padding: 0;
  z-index: 1;
}
.lb-close:hover { background: rgba(255, 255, 255, 0.18); }

.lb-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.8);
  cursor: pointer;
  border-radius: 50%;
  transition: background 0.15s;
  padding: 0;
  z-index: 1;
}
.lb-nav:hover { background: rgba(255, 255, 255, 0.18); }
.lb-prev { left: 1rem; }
.lb-next { right: 1rem; }

/*
  lb-media is a viewport-sized flex container with a DEFINITE height
  (100% of the full-screen .lightbox). The media is sized with object-fit
  so portrait and landscape both scale to fit without cropping. Padding
  keeps the media clear of the close/nav buttons.
*/
.lb-media {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  padding: 4.5rem 5rem;
  box-sizing: border-box;
}

/*
  :global() is required: the lightbox img/video are created at runtime
  via document.createElement, so they never receive Astro's scoped
  data-astro-cid attribute. Without :global these rules wouldn't match
  the dynamic media and it would render at full natural size.
*/
.lb-media :global(img),
.lb-media :global(video) {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
  border-radius: 6px;
  display: block;
}

.lb-media :global(img) { max-width: min(100%, 1200px); }
.lb-media :global(video) {
  max-width: min(100%, 960px);
  background: #000;
}

.lb-caption {
  position: absolute;
  bottom: 1rem;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255, 255, 255, 0.45);
  font-size: 0.75rem;
  white-space: nowrap;
  pointer-events: none;
}

@media (max-width: 640px) {
  .carousel-viewport { height: 340px; }
  .lb-prev { left: 0.375rem; }
  .lb-next { right: 0.375rem; }
  .lightbox { padding: 0; }
  .lb-media { padding: 3.5rem 3rem; }
}
</style>

<script define:vars={{ items }}>
  const track     = document.getElementById('cTrack');
  const dots      = Array.from(document.querySelectorAll('#cDots .c-dot'));
  const captionEl = document.getElementById('cCaption');
  const prevBtn   = document.getElementById('cPrev');
  const nextBtn   = document.getElementById('cNext');
  const pauseBtn  = document.getElementById('cPause');
  const pauseIcon = document.getElementById('cPauseIcon');
  const enlargeBtn = document.getElementById('cEnlarge');

  const lightbox  = document.getElementById('cLightbox');
  const lbMedia   = document.getElementById('lbMedia');
  const lbCaption = document.getElementById('lbCaption');
  const lbClose   = document.getElementById('lbClose');
  const lbPrev    = document.getElementById('lbPrev');
  const lbNext    = document.getElementById('lbNext');

  let current = 0;
  let playing = items.length > 1;
  let timer = null;

  const PAUSE_HTML = '<rect x="4" y="3" width="3" height="10" rx="1"/><rect x="9" y="3" width="3" height="10" rx="1"/>';
  const PLAY_HTML  = '<path d="M5 3l9 5-9 5V3z"/>';

  function slideVideo(idx) {
    return track.children[idx]?.querySelector('video') ?? null;
  }

  function goTo(idx) {
    // Pause + reset video leaving the stage
    const leaving = slideVideo(current);
    if (leaving) { leaving.pause(); leaving.currentTime = 0; }

    current = ((idx % items.length) + items.length) % items.length;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
    captionEl.textContent = items[current].caption || '';

    // Play video entering the stage
    const entering = slideVideo(current);
    if (entering) entering.play().catch(() => {});
  }

  function resetTimer() {
    clearInterval(timer);
    if (playing && items.length > 1) {
      timer = setInterval(() => goTo(current + 1), 4000);
    }
  }

  function togglePlay() {
    playing = !playing;
    if (pauseIcon) pauseIcon.innerHTML = playing ? PAUSE_HTML : PLAY_HTML;
    pauseBtn.setAttribute('aria-label', playing ? 'Pause' : 'Play');
    pauseBtn.setAttribute('title', playing ? 'Pause' : 'Play');
    resetTimer();
  }

  prevBtn?.addEventListener('click', () => { goTo(current - 1); resetTimer(); });
  nextBtn?.addEventListener('click', () => { goTo(current + 1); resetTimer(); });
  pauseBtn?.addEventListener('click', togglePlay);

  dots.forEach((d, i) => d.addEventListener('click', () => { goTo(i); resetTimer(); }));

  // Click slide -> enlarge
  track.addEventListener('click', () => openLightbox(current));

  // Swipe
  let touchX = 0;
  track.addEventListener('touchstart', (e) => { touchX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', (e) => {
    const dx = touchX - e.changedTouches[0].clientX;
    if (Math.abs(dx) > 40) { goTo(dx > 0 ? current + 1 : current - 1); resetTimer(); }
  });

  // Lightbox
  function renderLb() {
    lbMedia.innerHTML = '';
    const item = items[current];
    let el;
    if (item.type === 'image') {
      el = document.createElement('img');
      el.src = item.src;
      el.alt = item.caption || '';
    } else {
      el = document.createElement('video');
      el.src = item.src;
      el.controls = true;
      el.autoplay = true;
      el.muted = true;
      el.setAttribute('playsinline', '');
    }
    lbMedia.appendChild(el);
    lbCaption.textContent = item.caption || '';
  }

  function openLightbox(idx) {
    // Pause carousel video so two don't play at once
    const cv = slideVideo(current);
    if (cv) cv.pause();

    current = idx;
    renderLb();
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.hidden = true;
    document.body.style.overflow = '';
    lbMedia.innerHTML = '';

    // Resume carousel video if we're on a video slide
    const cv = slideVideo(current);
    if (cv) cv.play().catch(() => {});
  }

  enlargeBtn.addEventListener('click', (e) => { e.stopPropagation(); openLightbox(current); });
  lbClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });

  lbPrev?.addEventListener('click', (e) => { e.stopPropagation(); current = ((current - 1) + items.length) % items.length; renderLb(); });
  lbNext?.addEventListener('click', (e) => { e.stopPropagation(); current = (current + 1) % items.length; renderLb(); });

  document.addEventListener('keydown', (e) => {
    if (lightbox.hidden) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft'  && lbPrev) { current = ((current - 1) + items.length) % items.length; renderLb(); }
    if (e.key === 'ArrowRight' && lbNext) { current = (current + 1) % items.length; renderLb(); }
  });

  // Init
  goTo(0);
  resetTimer();
</script>