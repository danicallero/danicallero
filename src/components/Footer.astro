---
---

<footer style="border-top:1px solid var(--line); margin-top:6rem;">
  <div class="container" style="padding-block:2.5rem; display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
    <span style="font-family:'Baskerville Old Face',serif; font-size:0.9375rem; letter-spacing:-0.01em; color:var(--text-2);">
      Daniel Callero
    </span>
    <div style="display:flex; align-items:center; gap:1.5rem;">
      <a href="https://github.com/danicallero" target="_blank" rel="noopener noreferrer"
         style="font-size:0.75rem; color:var(--text-3); letter-spacing:0.04em; transition:color 0.15s;"
         onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-3)'">
        GitHub
      </a>
      <a href="https://links.danicallero.es" target="_blank" rel="noopener noreferrer"
         style="font-size:0.75rem; color:var(--text-3); letter-spacing:0.04em; transition:color 0.15s;"
         onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-3)'">
        Links
      </a>
      <span style="font-size:0.75rem; color:var(--text-3);">
        © {new Date().getFullYear()}
      </span>
    </div>
  </div>
</footer>
