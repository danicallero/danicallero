---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function extractPostImages(body: string) {
  const matches = [...body.matchAll(/!\[[^\]]*\]\(([^)]+)\)/g)];
  return matches
    .map((match) => match[1].trim().replace(/^<|>$/g, ''))
    .map((src) => src.replace(/\s+"[^"]*"$/, ''))
    .filter(Boolean)
    .map((src) => {
      try {
        // Avoid double-encoding paths that are already percent-encoded.
        return encodeURI(decodeURI(src));
      } catch {
        return src;
      }
    });
}

const postsWithImages = posts.map((post) => ({
  ...post,
  previewImages: extractPostImages(post.body),
}));

const byYear = postsWithImages.reduce<Record<number, typeof postsWithImages>>((acc, post) => {
  const yr = post.data.date.getFullYear();
  (acc[yr] ??= []).push(post);
  return acc;
}, {});
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---

<BaseLayout
  title="Blog · Daniel Callero"
  description="Writing by Daniel Callero."
>
  <Header />

  <main style="padding-top:6rem;">
    <div class="container">

      <header style="padding-block:4rem 3rem;">
        <p class="label">Writing</p>
        <h1 class="page-title">Notes, write-ups, and&nbsp;occasional&nbsp;thoughts.</h1>
      </header>

      {posts.length === 0 ? (
        <p style="color:var(--text-2); font-size:0.9375rem; font-style:italic; padding-bottom:4rem;">
          Posts coming soon.
        </p>
      ) : (
        <div style="padding-bottom:4rem;">
          {years.map((year) => (
            <section style="margin-bottom:3rem;" class="reveal">
              <p class="label" style="margin-bottom:0.5rem;">{year}</p>
              <div class="post-list">
                {byYear[year].map((post) => (
                  <a href={`/blog/${post.slug}`} class="post-item">
                    <span class="post-item-main">
                      <span class="post-title">{post.data.title}</span>
                      <span class="post-date">
                        {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                      </span>
                    </span>
                    {post.previewImages.length > 0 && (
                      <span
                        class="post-preview"
                        data-post-preview
                        data-images={JSON.stringify(post.previewImages)}
                        aria-hidden="true"
                      >
                        <img src={post.previewImages[0]} alt="" loading="lazy" decoding="async" />
                      </span>
                    )}
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      )}

    </div>
  </main>

  <Footer />

  <script is:inline>
    (() => {
      const windows = Array.from(document.querySelectorAll('[data-post-preview]'));
      if (!windows.length) return;

      const applyOrientation = (windowEl, imgEl) => {
        if (!imgEl.naturalWidth || !imgEl.naturalHeight) return;
        const isLandscape = imgEl.naturalWidth > imgEl.naturalHeight;
        windowEl.classList.toggle('is-landscape', isLandscape);
      };

      windows.forEach((windowEl) => {
        const images = JSON.parse(windowEl.getAttribute('data-images') || '[]');
        const img = windowEl.querySelector('img');
        if (!img) return;

        img.addEventListener('load', () => applyOrientation(windowEl, img));
        if (img.complete) applyOrientation(windowEl, img);

        if (images.length < 2) return;

        let index = 0;
        window.setInterval(() => {
          index = (index + 1) % images.length;
          img.src = images[index];
        }, 3200);
      });
    })();
  </script>
</BaseLayout>
