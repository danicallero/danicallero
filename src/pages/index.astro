---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { projects } from '../data/projects';
import { getCollection } from 'astro:content';

function normalizeSrc(src: string) {
  try {
    // Avoid double-encoding paths that are already percent-encoded.
    return encodeURI(decodeURI(src));
  } catch {
    return src;
  }
}

function extractPostImages(body: string) {
  const matches = [...body.matchAll(/!\[[^\]]*\]\(([^)]+)\)/g)];
  return matches
    .map((match) => match[1].trim().replace(/^<|>$/g, ''))
    .map((src) => src.replace(/\s+"[^"]*"$/, ''))
    .filter(Boolean)
    .map(normalizeSrc);
}

// Prefer the post's gallery images (first gallery pic leads); fall back to
// images embedded in the markdown body.
function galleryImages(gallery: { type: string; src: string }[] | undefined) {
  return (gallery ?? [])
    .filter((item) => item.type === 'image')
    .map((item) => normalizeSrc(item.src));
}

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)
  .map((post) => {
    const fromGallery = galleryImages(post.data.gallery);
    return {
      ...post,
      previewImages: fromGallery.length > 0 ? fromGallery : extractPostImages(post.body),
    };
  });

const featured = projects.filter((p) => p.featured).slice(0, 4);
---

<BaseLayout
  title="Daniel Callero"
  description="Personal site of Daniel (Dani) Callero. Developer from A Coruña, Spain."
>
  <Header />

  <main>
    <!-- ── Hero ─────────────────────────────────────────── -->
    <section class="hero">
      <div class="container">
        <div class="hero-inner">
          <h1 class="hero-name">Daniel<br>Callero</h1>
          <p class="hero-role">CS student &amp; aspiring developer</p>
          <p class="hero-location">A Coruña, Spain</p>
          <div class="hero-ctas">
            <a href="/projects" class="cta-primary">
              Projects
              <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </a>
            <span class="cta-divider" aria-hidden="true"></span>
            <a href="/about" class="cta-primary">About</a>
            <span class="cta-divider" aria-hidden="true"></span>
            <a
              href="https://github.com/danicallero"
              target="_blank"
              rel="noopener noreferrer"
              class="cta-primary"
            >
              GitHub
              <svg width="10" height="10" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h8v8M4 12 12 4"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Selected work ─────────────────────────────────── -->
    {featured.length > 0 && (
      <section class="section">
        <div class="container">
          <span class="label reveal">Work</span>
          <h2 class="section-heading reveal">Selected projects</h2>
          <div class="work-list reveal">
            {featured.map((p, i) => (
              <a
                href={`/projects/${p.slug}`}
                class="work-item"
              >
                <span class="work-num">{String(i + 1).padStart(2, '0')}</span>
                <div>
                  <div class="work-title">{p.title}</div>
                  {p.description && (
                    <div style="font-size:0.8125rem; color:var(--text-2); margin-top:0.2rem; line-height:1.5; max-width:480px;">
                      {p.description}
                    </div>
                  )}
                </div>
                <div class="work-meta">
                  <span class="work-tags">{p.tags.join(' · ')}</span>
                  <span class="work-year">{p.year}</span>
                  <span class="work-arrow">→</span>
                </div>
              </a>
            ))}
          </div>
          <a href="/projects" class="see-all reveal">
            All projects
            <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        </div>
      </section>
    )}

    <!-- ── Writing ────────────────────────────────────────── -->
    {allPosts.length > 0 && (
      <section class="section">
        <div class="container">
          <span class="label reveal">Blog</span>
          <h2 class="section-heading reveal">Recent writing</h2>
          <div class="post-list reveal">
            {allPosts.map((post) => (
              <a href={`/blog/${post.slug}`} class="post-item">
                <span class="post-item-main">
                  <span class="post-title">{post.data.title}</span>
                  <span class="post-date">
                    {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </span>
                </span>
                {post.previewImages.length > 0 && (
                  <span
                    class="post-preview"
                    data-post-preview
                    data-images={JSON.stringify(post.previewImages)}
                    aria-hidden="true"
                  >
                    <img src={post.previewImages[0]} alt="" loading="lazy" decoding="async" />
                  </span>
                )}
              </a>
            ))}
          </div>
          <a href="/blog" class="see-all reveal">
            All posts
            <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        </div>
      </section>
    )}

    <!-- ── About brief ────────────────────────────────────── -->
    <section class="section">
      <div class="container">
        <span class="label reveal">About</span>
        <h2 class="section-heading reveal">Who I am</h2>
        <p class="about-blurb reveal">
          Aspiring developer, chaotic thinker, lifelong learner, and tech enthusiast. I'm studying Computer Science in A Coruña, Spain.
        </p>
        <a href="/about" class="see-all reveal" style="margin-top:2rem;">
          More about me
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline>
    (() => {
      const windows = Array.from(document.querySelectorAll('[data-post-preview]'));
      if (!windows.length) return;

      const applyOrientation = (windowEl, imgEl) => {
        if (!imgEl.naturalWidth || !imgEl.naturalHeight) return;
        const isLandscape = imgEl.naturalWidth > imgEl.naturalHeight;
        windowEl.classList.toggle('is-landscape', isLandscape);
      };

      windows.forEach((windowEl) => {
        const images = JSON.parse(windowEl.getAttribute('data-images') || '[]');
        const img = windowEl.querySelector('img');
        if (!img) return;

        img.addEventListener('load', () => applyOrientation(windowEl, img));
        if (img.complete) applyOrientation(windowEl, img);

        if (images.length < 2) return;

        let index = 0;
        window.setInterval(() => {
          index = (index + 1) % images.length;
          img.src = images[index];
        }, 3200);
      });
    })();
  </script>
</BaseLayout>
