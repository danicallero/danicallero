---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { projects } from '../data/projects';
---

<BaseLayout
  title="Projects · Daniel Callero"
  description="Coding projects by Daniel Callero."
>
  <Header />

  <main style="padding-top:6rem;">
    <div class="container">

      <!-- Page header -->
      <header style="padding-block:4rem 3rem;">
        <p class="label">Work</p>
        <h1 class="page-title" style="max-width:480px;">
          Things I've built.
        </h1>
      </header>

      <!-- Projects list -->
      <div class="work-list reveal">
        {projects.map((p, i) => (
          <a
            href={p.url ?? p.github ?? '#'}
            target={p.url ?? p.github ? '_blank' : undefined}
            rel="noopener noreferrer"
            class="work-item"
          >
            <span class="work-num">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <div class="work-title">{p.title}</div>
              {p.description && (
                <div style="font-size:0.8125rem; color:var(--text-2); margin-top:0.3rem; line-height:1.55; max-width:520px;">
                  {p.description}
                </div>
              )}
            </div>
            <div class="work-meta">
              <span class="work-tags">{p.tags.join(' · ')}</span>
              <span class="work-year">{p.year}</span>
              <span class="work-arrow">↗</span>
            </div>
          </a>
        ))}
        {projects.length === 0 && (
          <p style="padding-block:2rem; color:var(--text-2); font-size:0.875rem; font-style:italic;">
            Projects coming soon.
          </p>
        )}
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>
