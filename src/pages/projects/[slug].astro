---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Gallery from '../../components/Gallery.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project: p } = Astro.props;
---

<BaseLayout
  title={`${p.title} · Daniel Callero`}
  description={p.description}
>
  <Header />

  <main style="padding-top:6rem;">
    <div class="container">

      <!-- Back (defaults to /projects; rewritten to the referring page when
           the visitor arrived from elsewhere on the site, e.g. a blog post) -->
      <div style="padding-block:2.5rem 0;">
        <a
          id="project-back"
          href="/projects"
          style="font-size:0.8125rem; color:var(--text-3); letter-spacing:0.04em; transition:color 0.15s; display:inline-flex; align-items:center; gap:0.375rem;"
          onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-3)'"
        >
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 8H3M7 4l-4 4 4 4"/></svg>
          <span class="back-label">Projects</span>
        </a>
      </div>
      <script>
        // Re-point the back link at wherever the visitor actually came from.
        // Runs on every View Transitions navigation (not just first load), and
        // always resets to the default first so a previous page's decision can
        // never linger. The origin is read from the navigation record written
        // in BaseLayout — document.referrer is stale under View Transitions.
        function updateProjectBack() {
          const back = document.getElementById('project-back');
          if (!back) return;
          const label = back.querySelector('.back-label');

          // Reset to the default before deciding.
          back.setAttribute('href', '/projects');
          if (label) label.textContent = 'Projects';

          let from = '';
          try {
            const raw = sessionStorage.getItem('backNav');
            if (raw) {
              const rec = JSON.parse(raw);
              // Only trust the record if it was written for this destination.
              if (rec && rec.to === location.pathname) from = rec.from || '';
            }
          } catch {}
          if (!from && document.referrer) {
            try {
              const u = new URL(document.referrer);
              if (u.origin === location.origin) from = u.pathname + u.search;
            } catch {}
          }
          if (!from) return;

          if (from.startsWith('/blog/') && from.length > '/blog/'.length) {
            back.setAttribute('href', from);
            if (label) label.textContent = 'Article';
          } else if (from === '/') {
            back.setAttribute('href', '/');
            if (label) label.textContent = 'Home';
          }
        }

        updateProjectBack();
        document.addEventListener('astro:page-load', updateProjectBack);
      </script>

      <!-- Header -->
      <header style="padding-block:2.5rem 3rem; border-bottom:1px solid var(--line);">
        <p class="label">{p.year}</p>
        <h1 class="page-title" style="font-size:clamp(1.75rem,5vw,2.75rem); max-width:600px; margin-bottom:1.25rem;">
          {p.title}
        </h1>
        <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
          {p.tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      </header>

      <!-- Gallery (only rendered when items are set) -->
      {p.gallery && p.gallery.length > 0 && (
        <Gallery items={p.gallery} />
      )}

      <!-- Video (only rendered when a URL is set) -->
      {p.videoEmbedUrl && (
        <section style="padding-block:3rem; border-bottom:1px solid var(--line);">
          <p class="label" style="margin-bottom:1.25rem;">Demo</p>
          <div style="position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:12px; border:1px solid var(--border); background:var(--surface);">
            <iframe
              src={p.videoEmbedUrl}
              title={`${p.title} demo`}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              style="position:absolute; inset:0; width:100%; height:100%; border:none;"
            ></iframe>
          </div>
        </section>
      )}

      <!-- Description -->
      <section style="padding-block:3rem; border-bottom:1px solid var(--line); max-width:640px;">
        <p class="label" style="margin-bottom:1.25rem;">About this project</p>
        <div style="display:flex; flex-direction:column; gap:1.1rem;">
          {p.longDescription
            .split(/\n{2,}/)
            .map((para) => para.trim())
            .filter(Boolean)
            .map((para) => (
              <p style="font-size:0.9375rem; color:var(--text-2); line-height:1.8;">{para}</p>
            ))}
        </div>
      </section>

      <!-- Highlights -->
      <section style="padding-block:3rem; border-bottom:1px solid var(--line);">
        <p class="label" style="margin-bottom:1.5rem;">Key highlights</p>
        <ul style="list-style:none; display:flex; flex-direction:column; gap:0.875rem; max-width:560px;">
          {p.highlights.map((h) => (
            <li style="display:grid; grid-template-columns:1rem 1fr; gap:0.75rem; align-items:baseline;">
              <span style="font-size:0.5rem; color:var(--text-3); padding-top:0.35em;">●</span>
              <span style="font-size:0.9375rem; color:var(--text-2); line-height:1.6;">{h}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Links -->
      <section style="padding-block:3rem 4rem; display:flex; gap:1rem; flex-wrap:wrap;">
        {p.github && (
          <a
            href={p.github}
            target="_blank"
            rel="noopener noreferrer"
            style="display:inline-flex; align-items:center; gap:0.5rem; font-size:0.8125rem; color:var(--text); border:1px solid var(--border); padding:0.5rem 1rem; border-radius:4px; letter-spacing:0.01em; transition:opacity 0.15s;"
            onmouseover="this.style.opacity='0.55'" onmouseout="this.style.opacity='1'"
          >
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
            Source code
          </a>
        )}
        {p.url && (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            style="display:inline-flex; align-items:center; gap:0.5rem; font-size:0.8125rem; color:var(--text); border:1px solid var(--border); padding:0.5rem 1rem; border-radius:4px; letter-spacing:0.01em; transition:opacity 0.15s;"
            onmouseover="this.style.opacity='0.55'" onmouseout="this.style.opacity='1'"
          >
            Live site
            <svg width="10" height="10" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h8v8M4 12 12 4"/></svg>
          </a>
        )}
      </section>

    </div>
  </main>

  <Footer />
</BaseLayout>
